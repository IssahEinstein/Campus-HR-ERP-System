# Copy these values into your Render web service environment variables.
# Do not commit real credentials.

# Prisma / Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# JWT
SECRET_KEY="replace-with-a-long-random-secret"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL for invite links and CORS-facing flows
FRONTEND_URL="https://your-frontend-domain.onrender.com"

# Optional one-time admin bootstrap key
ADMIN_BOOTSTRAP_KEY="set-once-then-remove-or-rotate"

# SMTP (optional if your flow needs outgoing emails)
SMTP_HOST="smtp-relay.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@example.com"
